    {
      "apiVersion": "batch/v1",
      "kind": "CronJob",
      "metadata": {
        "annotations": {},
        "labels": {
          "app.kubernetes.io/component": "object-metrics-scraper",
          "app.kubernetes.io/name": "prod-pg-inspector-metrics",
          "postgres-operator.crunchydata.com/cluster": "prod-pgcluster-uae"
        },
        "name": "prod-pg-inspector-object-metrics",
        "namespace": "prod-pgcluster-uae"
      },
      "spec": {
        "concurrencyPolicy": "Forbid",
        "failedJobsHistoryLimit": 3,
        "jobTemplate": {
          "metadata": {
            "creationTimestamp": null
          },
          "spec": {
            "backoffLimit": 1,
            "template": {
              "metadata": {
                "creationTimestamp": null,
                "labels": {
                  "app.kubernetes.io/component": "object-metrics-scraper",
                  "app.kubernetes.io/name": "prod-pg-inspector-metrics"
                }
              },
              "spec": {
                "automountServiceAccountToken": false,
                "containers": [
                  {
                    "command": [
                      "/bin/bash",
                      "-lc",
                      "/opt/pg-inspector/publish-prod-pg-inspector-metrics.sh"
                    ],
                    "env": [
                      {
                        "name": "NS",
                        "value": "prod-pgcluster-uae"
                      },
                      {
                        "name": "CLUSTER",
                        "value": "prod-pgcluster-uae"
                      },
                      {
                        "name": "PGINSPECTOR_CONNECT_MODE",
                        "value": "direct"
                      },
                      {
                        "name": "PUSHGATEWAY_URL",
                        "value": "http://prod-pgo18-pgbackrest-pushgateway:9091"
                      },
                      {
                        "name": "PUSHGATEWAY_JOB",
                        "value": "pg-inspector-object-report"
                      },
                      {
                        "name": "PUSHGATEWAY_INSTANCE",
                        "value": "prod-pgcluster-uae"
                      },
                      {
                        "name": "METRICS_OUTPUT",
                        "value": "/tmp/pg_inspector_metrics.prom"
                      },
                      {
                        "name": "PYTHONDONTWRITEBYTECODE",
                        "value": "1"
                      },
                      {
                        "name": "PGHOST",
                        "valueFrom": {
                          "secretKeyRef": {
                            "key": "host",
                            "name": "prod-pgcluster-uae-pguser-postgres"
                          }
                        }
                      },
                      {
                        "name": "PGPORT",
                        "valueFrom": {
                          "secretKeyRef": {
                            "key": "port",
                            "name": "prod-pgcluster-uae-pguser-postgres"
                          }
                        }
                      },
                      {
                        "name": "PGUSER",
                        "valueFrom": {
                          "secretKeyRef": {
                            "key": "user",
                            "name": "prod-pgcluster-uae-pguser-postgres"
                          }
                        }
                      },
                      {
                        "name": "PGPASSWORD",
                        "valueFrom": {
                          "secretKeyRef": {
                            "key": "password",
                            "name": "prod-pgcluster-uae-pguser-postgres"
                          }
                        }
                      }
                    ],
                    "image": "registry.connect.redhat.com/crunchydata/crunchy-postgres@sha256:3c38e7be43392c37e7d72ee3a8387e1931f342e42c7c5b7c88559d865c4cc024",
                    "imagePullPolicy": "IfNotPresent",
                    "name": "scraper",
                    "resources": {
                      "limits": {
                        "cpu": "500m",
                        "memory": "512Mi"
                      },
                      "requests": {
                        "cpu": "25m",
                        "memory": "128Mi"
                      }
                    },
                    "securityContext": {
                      "allowPrivilegeEscalation": false,
                      "capabilities": {
                        "drop": [
                          "ALL"
                        ]
                      },
                      "privileged": false,
                      "readOnlyRootFilesystem": true,
                      "runAsNonRoot": true,
                      "seccompProfile": {
                        "type": "RuntimeDefault"
                      }
                    },
                    "terminationMessagePath": "/dev/termination-log",
                    "terminationMessagePolicy": "File",
                    "volumeMounts": [
                      {
                        "mountPath": "/opt/pg-inspector",
                        "name": "scripts",
                        "readOnly": true
                      },
                      {
                        "mountPath": "/tmp",
                        "name": "tmp"
                      }
                    ]
                  }
                ],
                "dnsPolicy": "ClusterFirst",
                "enableServiceLinks": false,
                "restartPolicy": "Never",
                "schedulerName": "default-scheduler",
                "securityContext": {},
                "serviceAccount": "prod-pg-inspector-metrics",
                "serviceAccountName": "prod-pg-inspector-metrics",
                "terminationGracePeriodSeconds": 30,
                "volumes": [
                  {
                    "configMap": {
                      "defaultMode": 365,
                      "name": "prod-pg-inspector-metrics-scripts"
                    },
                    "name": "scripts"
                  },
                  {
                    "emptyDir": {
                      "sizeLimit": "32Mi"
                    },
                    "name": "tmp"
                  }
                ]
              }
            }
          }
        },
        "schedule": "*/15 * * * *",
        "successfulJobsHistoryLimit": 3,
        "suspend": false
      }
    },
